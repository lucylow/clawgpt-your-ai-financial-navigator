# Copy to .env and fill values. Never commit real secrets.

# Optional: POST JSON batches of client observability events (errors, interactions, chain logs, Web Vitals).
# VITE_OBSERVABILITY_INGEST_URL=https://your-api.example/observability/ingest

# Optional: app served under a subpath (must start with /). Vite `base` + React Router stay in sync.
# Example: VITE_BASE_PATH=/my-app  →  assets at /my-app/… and routes under /my-app/…
# VITE_BASE_PATH=

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# When true (or when URL/key missing), chat uses rich mock agent responses for demos.
VITE_USE_MOCK_AGENT=true

# Set to true to require a real Supabase session for /app (disables demo-wallet-only bypass).
# VITE_REQUIRE_AUTH_FOR_APP=false

# Optional: EVM testnet recipient for assistant “send” confirmations when WDK is connected.
# VITE_DEMO_TRANSFER_RECIPIENT=0x000000000000000000000000000000000000dEaD

# Tether WDK — set to false to force the rich mock portfolio (no @tetherto packages needed at runtime).
VITE_USE_WDK=true

# Testnet RPCs (public defaults work for demos; use Alchemy/Infura for reliability)
VITE_ETH_RPC_SEPOLIA=https://sepolia.drpc.org
VITE_POLYGON_RPC_AMOY=https://rpc-amoy.polygon.technology
VITE_ARBITRUM_RPC_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
VITE_TRON_RPC_SHASTA=https://api.shasta.trongrid.io
VITE_SOLANA_RPC_DEVNET=https://api.devnet.solana.com
VITE_TON_RPC_TESTNET=https://testnet.toncenter.com/api/v2/jsonRPC

# Optional Toncenter API key (higher rate limits)
# VITE_TONCENTER_API_KEY=

# ERC-20 / mint addresses for USDt / XAUt on each testnet — required for non-zero token balances.
# Leave blank to show $0 until you configure faucet tokens.
# VITE_USDT_ETHEREUM_SEPOLIA=
# VITE_XAUT_ETHEREUM_SEPOLIA=

# Optional faucet APIs
# PIMLICO_FAUCET_API_KEY=your-key
