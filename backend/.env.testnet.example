# Copy to backend/.env — use with docker-compose Postgres or your own DATABASE_URL
PORT=8787
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
AUTONOMY_CRON_ENABLED=0
LOG_LEVEL=info
BACKEND_ENCRYPTION_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clawgpt_agent

# Optional: OpenAI-compatible JSON planner (otherwise pattern-based OpenClaw)
AGENT_LLM_BASE_URL=https://api.openai.com
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=gpt-4o-mini

# Chain RPCs (testnets)
ETH_RPC_SEPOLIA=https://sepolia.drpc.org
POLYGON_RPC_AMOY=https://rpc-amoy.polygon.technology
ARBITRUM_RPC_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
SOLANA_RPC_DEVNET=https://api.devnet.solana.com
TRON_RPC_SHASTA=https://api.shasta.trongrid.io
TON_RPC_TESTNET=https://testnet.toncenter.com/api/v2/jsonRPC
TONCENTER_API_KEY=

# Tether token addresses (testnets) — required for real balance reads / transfers
USDT_ETHEREUM_SEPOLIA=
XAUt_ETHEREUM_SEPOLIA=
USDT_POLYGON_AMOY=
XAUt_POLYGON_AMOY=
USDT_ARBITRUM_SEPOLIA=
XAUt_ARBITRUM_SEPOLIA=
USDT_SOLANA_DEVNET=
XAUt_SOLANA_DEVNET=
USDT_TRON_SHASTA=
XAUt_TRON_SHASTA=
USDT_TON_TESTNET=
XAUt_TON_TESTNET=
USAt_ETHEREUM_SEPOLIA=
USAt_POLYGON_AMOY=
USAt_ARBITRUM_SEPOLIA=
